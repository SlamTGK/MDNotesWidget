<?xml version="1.0" encoding="utf-8"?>
<!--
    Widget background: simple shape with solid color + rounded corners.
    layer-list with gradient can crash RemoteViews on some devices.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1E1B4B" />
    <corners android:radius="16dp" />
</shape>
