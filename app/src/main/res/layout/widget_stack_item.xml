<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_stack_item_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_stack_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/widget_text_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/widget_stack_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textColor="@color/widget_text_content"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.3"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_stack_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#999999"
        android:textSize="9sp"
        android:maxLines="1"
        android:layout_marginTop="6dp" />

</LinearLayout>
