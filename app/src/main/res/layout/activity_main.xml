<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp">

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_launcher_foreground"
                android:background="@drawable/ic_launcher_background"
                android:contentDescription="@string/app_name"
                android:padding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/app_name"
                android:textColor="?colorOnSurface"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/settings_subtitle"
                android:textColor="?colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ── Card: Folder ───────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/folder_settings"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_folder_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/folder_path_hint"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:ellipsize="middle"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tv_file_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="?colorSecondary"
                    android:textSize="11sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_folder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/select_folder"
                    style="@style/Widget.Material3.Button.TonalButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card: Interval ─────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/interval_settings"
                        android:textColor="?colorPrimary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_interval_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorOnSurface"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbar_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:max="25"
                    android:progress="0"
                    android:progressTint="?colorPrimary"
                    android:thumbTint="?colorPrimary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/interval_off"
                        android:textColor="?colorOnSurfaceVariant"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/interval_max"
                        android:textColor="?colorOnSurfaceVariant"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card: Open with ────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/open_with_settings"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/radio_group_open_with"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <RadioButton
                        android:id="@+id/radio_viewer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/built_in_viewer"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:buttonTint="?colorPrimary"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radio_obsidian"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/obsidian"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:buttonTint="?colorPrimary" />

                    <RadioButton
                        android:id="@+id/radio_system"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/system_chooser"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:buttonTint="?colorPrimary" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card: Widget Theme ─────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_settings"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/radio_group_theme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <RadioButton
                        android:id="@+id/radio_theme_default"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="@string/theme_default"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:buttonTint="?colorPrimary" />

                    <RadioButton
                        android:id="@+id/radio_theme_dark"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="@string/theme_dark"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:buttonTint="?colorPrimary" />

                    <RadioButton
                        android:id="@+id/radio_theme_transparent"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="@string/theme_transparent"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:buttonTint="?colorPrimary" />

                    <RadioButton
                        android:id="@+id/radio_theme_custom"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="@string/theme_custom"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:buttonTint="?colorPrimary" />
                </RadioGroup>

                <!-- Custom colors panel (shown when custom theme is selected) -->
                <LinearLayout
                    android:id="@+id/custom_colors_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <!-- Background color -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/custom_bg_color"
                            android:textColor="?colorOnSurface"
                            android:textSize="13sp" />

                        <View
                            android:id="@+id/color_preview_bg"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="#1E1B4B" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pick_bg_color"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:text="@string/pick_color"
                            android:textSize="11sp"
                            style="@style/Widget.Material3.Button.TonalButton" />
                    </LinearLayout>

                    <!-- Text color -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/custom_text_color"
                            android:textColor="?colorOnSurface"
                            android:textSize="13sp" />

                        <View
                            android:id="@+id/color_preview_text"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="#F8FAFC" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pick_text_color"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:text="@string/pick_color"
                            android:textSize="11sp"
                            style="@style/Widget.Material3.Button.TonalButton" />
                    </LinearLayout>

                    <!-- Title color -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/custom_title_color"
                            android:textColor="?colorOnSurface"
                            android:textSize="13sp" />

                        <View
                            android:id="@+id/color_preview_title"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="#FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pick_title_color"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:text="@string/pick_color"
                            android:textSize="11sp"
                            style="@style/Widget.Material3.Button.TonalButton" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card: Font Size ────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/font_settings"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/radio_group_font"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <RadioButton
                        android:id="@+id/radio_font_small"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/font_small"
                        android:textColor="?colorOnSurface"
                        android:textSize="12sp"
                        android:buttonTint="?colorPrimary" />

                    <RadioButton
                        android:id="@+id/radio_font_medium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/font_medium"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:buttonTint="?colorPrimary" />

                    <RadioButton
                        android:id="@+id/radio_font_large"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/font_large"
                        android:textColor="?colorOnSurface"
                        android:textSize="16sp"
                        android:buttonTint="?colorPrimary" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card: Tag Filter + Logic ───────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tag_settings"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/tag_desc"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/edit_tag_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/tag_hint"
                    android:inputType="text"
                    android:textColor="?colorOnSurface"
                    android:textColorHint="?colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:paddingBottom="12dp" />

                <!-- Tag logic: AND / OR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/tag_logic_label"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/radio_group_tag_logic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/radio_tag_or"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="@string/tag_logic_or"
                        android:textColor="?colorOnSurface"
                        android:textSize="13sp"
                        android:buttonTint="?colorPrimary"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radio_tag_and"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="@string/tag_logic_and"
                        android:textColor="?colorOnSurface"
                        android:textSize="13sp"
                        android:buttonTint="?colorPrimary" />
                </RadioGroup>

                <!-- Folder blacklist -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/blacklist_settings"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edit_folder_blacklist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/blacklist_hint"
                    android:inputType="text"
                    android:textColor="?colorOnSurface"
                    android:textColorHint="?colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:paddingBottom="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card: Quiet Hours ──────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quiet_hours_settings"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/quiet_hours_desc"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textSize="11sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_quiet_hours"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/quiet_hours_enabled"
                    android:textColor="?colorOnSurface"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:id="@+id/quiet_hours_time_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quiet_hours_from"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_quiet_start"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:text="23:00"
                        android:textSize="14sp"
                        style="@style/Widget.Material3.Button.TonalButton" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/quiet_hours_to"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_quiet_end"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:text="07:00"
                        android:textSize="14sp"
                        style="@style/Widget.Material3.Button.TonalButton" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card: Actions ─────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/actions_section"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_widgets"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/refresh_all_widgets"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_files"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/refresh_file_list"
                    android:textSize="14sp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Author Credit -->
        <TextView
            android:id="@+id/tv_author_credit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:text="@string/author_credit"
            android:textColor="?colorOnSurfaceVariant"
            android:textSize="11sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2" />

    </LinearLayout>
</ScrollView>
