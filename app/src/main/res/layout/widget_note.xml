<?xml version="1.0" encoding="utf-8"?>
<!--
    Main widget layout. Uses ONLY RemoteViews-compatible views and attributes.
    NO layout_weight — not supported in RemoteViews on Android 12+.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- Top accent bar: purple → cyan gradient, 3dp tall -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/accent_line" />

    <!-- Note title -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="10dp"
        android:textColor="@color/widget_text_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="7dp"
        android:background="@color/widget_divider" />

    <!-- Note content preview — fixed height to work without layout_weight -->
    <TextView
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="7dp"
        android:textColor="@color/widget_text_content"
        android:textSize="12sp"
        android:lineSpacingExtra="2dp"
        android:ellipsize="end"
        android:maxLines="20" />

    <!-- Bottom bar: filename + refresh button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="6dp"
        android:paddingBottom="8dp"
        android:paddingTop="4dp">

        <TextView
            android:id="@+id/widget_filename"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/widget_text_filename"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="middle" />

        <ImageView
            android:id="@+id/widget_refresh_btn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_refresh"
            android:padding="5dp"
            android:alpha="0.6"
            android:contentDescription="@string/refresh" />

    </LinearLayout>

</LinearLayout>
