<?xml version="1.0" encoding="utf-8"?>
<!--
    Widget layout — ZERO layout_weight usage (crashes RemoteViews on Android 12+).
    Uses FrameLayout instead of View (View is NOT supported in RemoteViews).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@drawable/widget_background">

    <!-- Purple → cyan top accent line -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/accent_line" />

    <!-- Title -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="0dp"
        android:textColor="@color/widget_text_title"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="8dp"
        android:background="@color/widget_divider" />

    <!-- Note content — scrollable-friendly, no weight -->
    <TextView
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textColor="@color/widget_text_content"
        android:textSize="11sp"
        android:lineSpacingMultiplier="1.3"
        android:maxLines="15"
        android:ellipsize="end" />

    <!-- Spacer -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom row: filename + refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_filename"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/widget_text_filename"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/widget_refresh_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_refresh"
            android:padding="4dp"
            android:alpha="0.6"
            android:contentDescription="@string/refresh" />

    </LinearLayout>

</LinearLayout>
